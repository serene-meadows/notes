+
  when used with numbers
    + -> addition

  when String + anything
    + -> string concatenation

  when char + char
    + -> addition of the 2 byte representation of the chars, not concatenation

    if you wanted concatenation do string concatenation
      "" + char_var + char_var_2; // causes string concatenation because of ""

