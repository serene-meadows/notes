nvim . 
    d -> create directory
		D -> delete
		R -> rename
    % -> create file

:Ex -> netrw (default file explorer)
:source -> source file


custom
    <leader>pv -> open netrw (default file explorer) pv stands for project view
    <leader>pf -> find file
    <leader>pg -> find grep
    <leader>pb -> find buffer (open fies)
    <C-p> -> in normal mode -> find git files

		<leader>hm -> toggle harpoon menu
		<leader>ha -> harpoon add
		<leader>h1/2/3/4 -> harpoon switch

