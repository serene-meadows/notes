namespace
    named namespace
        namespace is a declarative region that provides a scope for 
            > functions
            > classes
            > variables
            > constants
            > templates
        it prevents name collision and helps organize large codebases

        example
            ```
            namespace MyNamespace {
                int value = 1;
                std::cout << value;
            }

            // use it with scope operator
            std::cout << MyNamespace::value;
            ```

    nested namespace
        you can have nested namespaces
        example
            ```
            namespace A {
                namespace B {
                    namespace C {
                    }
                }
            }
            ```

    anonymous namespace
        you can have anonymous namespaces,
        an anonymous namespace make it so that everything inside is only visible to that .cpp file
        so can think of it like file-private-scope

        example
            ```
            namespace {
                int x = 1;
            }
            std::cout << x;
            
            // but cannot use this in another file
            ```

        thus, 
            when two files having the same function names are compiled, it gives linker error
            but if they were in anonymous namespace, no problem since they are visible only within
            their files

template
    often times you can ommit the `<types...>` and the compiler can deduce it
    function
        basic syntax
            ```
            // Declare
            template<Typename T>
            T Add(T a, T b) {
                return a + b;
            }

            // Initialize
            Add<int>(1, 2);
            ```

        multiple parameters
            ```
            // Declare
            template<typename T, typename U>
            auto Add(T a, U b) {
                return a + b;
            }
            
            // Initialize
            Add<int, double>(1, 2.3);
            ```

        class 
            ```
            // Declare
            template<typename T>
            class Box {
                public:
                T value;
            }

            // Initialize
            Box<int> a;
            ```

        template specialization
            custom behaviour for a type
                ```
                // Generic Declaration
                template<typename T>
                T Square (T x) {
                    return x * x;
                }

                // Declaration for bool
                template<>
                Square<bool> (bool x) {
                    return x;
                }
                ```

        non type templates
            templates can take values too
            the value must be known at compile time
                ```
                // Declaration
                template<int N>
                class Buffer {
                    int data[N];
                }

                // Initialize
                Buffer<10> a;
                ```

enum
  enum -> enumeration 
  type that represent a fixed set of named values
    ```
    // Declaration
    enum GameState {
      START,   // 0
      PLAYING, // 1
      END      // 2
    };

    // Initialize
    GameState state = START;
    ```

  enums are still integers underneath
  default value is 0, 1, 2 ...

  we can assign values too
    ```
    enum ErrorCode {
      OK = 0,
      WARNING = 100,
      FATAL = 200
    };
    ```

  anonymous enums
    ```
    enum {
      MAX_MOVES = 10000,
      MAX_SQR   = 62
    };
    // equivalent to
    constexpr MAX_MOVES = 10000;
    constexpr MAX_SQR = 62;
    ```

enum class
  adds typesafety
  example where enum isn't good
    ```
    // traditional enums leak out of their "type"
    enum Piece {
      PAWN,
      KNIGHT
    }

    enum Card {
      PAWN, // CONFLICT
      KING
    }
    ```

    ```
    int x = PAWN; // Implicit conversion to int
    ```

  enum class
    ```
    // Declaration
    enum class Piece {
      Pawn, 
      Knight,
      Bishop
    };

    // Initialize
    Piece p = Piece::Pawn;
    ```

  now, they don't leak out of their "type", they don't implicitly convert to int

  ```
    // with normal enum
    int a = RED; // works

    // but with class enum
    int a = Color::RED;   // doesn't work
    Color a = Color::RED; // works
  ```

  you can specify internal int type
  ```
    enum class Piece: uint8_t {
      Pawn,
      Knight,
      Bishop
    };
  ```
  
header
  contain declarations not implementations
  basic structure
    ```
    // Header file
    #ifndef FILE_NAME_H
    #define FILE_NAME_H
    int add(int a, int b);
    int multiply(int a, int b);
    
    #endif

    // cpp file implementation file
    #include "FILE_NAME_H"

    int add(int a, int b) {
      return a + b;
    }

    int multiply(int a, int b) {
      retrun a * b;
    }
    
    // importing functionality
    #include "FILE_NAME_H" // you include the header not the cpp file

    int main () {
      std::cout << add(2, 3);
    }
    ```

  what typically goes in headers
    > function declarations `int evaluate(int a, int b);`
    > class declarations // method implementations go in cpp file
      ```
        class className {
          public:
          void search();
          void add();

          private:
          int depth;
        };
      ``` 
    > structs, enums, typedefs
    > constants, macros

  include guards
    without guards, headers can cause problems when included multiple times
    problem
      ```
        #include "fileA.h"
        #include "fileB.h" // also includes fileA within its file
      ```

    special case
      if using templates, they must be fully defined within the headers
  
    solutions
      ```
        #ifndef FILE_A_H
        @define FILE_A_H
        // ...
        #endif

        or on modern compilers

        #pragma once
      ```
        
abstract class
  abstract classes 
    > cannot be instantiated
    > have to be inherited to be used
    > serve as interfaces
    > contain atleast one pure virtual function
    > All functions don't have to be pure virtual

  pure virtual function
    `virtual void functionName() = 0;`
    derived class MUST implement this function

  example
    ```
    class Animal {
      public:
      virtual void makeSound() = 0;
    };

    Animal a; // cannot do

    class Dog : public Animal {
      public:
      void makeSound() override {
        std::cout << "woof";
      }
    };

    Dog d;
    d.makeSound();
    ```

